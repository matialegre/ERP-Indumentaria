          'AJUSTE','NRMPBSABS6NB0ST','NRMPBSABS2','1','3',
          'PTF3539APCOUT','PTF4539APCOUT','PTR2530APCOUT',
          'PTF7050APCOUT','DESCUENTO','NRMPBSABS1','NRMPBSABS5','2'
