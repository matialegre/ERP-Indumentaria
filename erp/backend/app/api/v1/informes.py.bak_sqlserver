)
SELECT
    LOCAL,
    CODIGO_ARTICULO,
    ARTICULO_LIMPIO,
    SUM(CANTIDAD_VENDIDA) AS TOTAL_VENDIDO
FROM VentasFiltradas
GROUP BY LOCAL, CODIGO_ARTICULO, ARTICULO_LIMPIO
