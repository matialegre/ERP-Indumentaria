# ─── Configuración del ERP ───
# Copiar este archivo a .env y completar con valores reales

# PostgreSQL
DATABASE_URL=postgresql://erp_user:CHANGE_ME@localhost:2048/erp_mundooutdoor

# JWT
JWT_SECRET=CHANGE_ME_USE_A_LONG_RANDOM_STRING
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# CORS (separados por coma)
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Admin inicial (se crea al primer arranque)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=CHANGE_ME

# Redis (opcional, para cache)
REDIS_URL=redis://localhost:6379/0
