# ─── Variables de entorno — ERP Mundo Outdoor ───
# Copiar este archivo como .env y ajustar los valores para tu entorno.

# Base de datos (interno Docker: puerto 5432; externo mapeado a 2048)
DATABASE_URL=postgresql://erp_user:MundoOutdoor2026!@db:5432/erp_mundooutdoor
POSTGRES_DB=erp_mundooutdoor
POSTGRES_USER=erp_user
POSTGRES_PASSWORD=MundoOutdoor2026!
POSTGRES_PORT=2048

# Seguridad
SECRET_KEY=change-me-in-production
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin

# CORS — orígenes permitidos (separados por coma)
CORS_ORIGINS=http://localhost:8000,http://192.168.0.122:8000

# Entorno
ENV=production
DEBUG=false
